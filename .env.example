# Required for the streaming /v1/chat action (set in .env for local aio, or App Builder secrets in cloud).
OPENAI_API_KEY=

# Optional. Examples: gpt-4o, gpt-4.1, or your org’s approved model id.
OPENAI_MODEL=gpt-4o

# Optional. Shown in model instructions and demo recommend payloads — set per brand deployment.
BRAND_DISPLAY_NAME=Your brand

# Optional — MCP action (`actions/mcp`) and deep-link resolution (see AGENTS.md).
# LLM_APP_BASE_URL=
# LLM_EXPERIENCE_ORIGIN=
# LLM_APP_OW_PACKAGE=
# LLM_CHATGPT_FRAME_DOMAINS=
# LLM_EXPERIENCE_USE_HASH_ROUTES=
# LLM_SPA_BASENAME=
# LLM_EXPERIENCE_DEV_PORT=
# LLM_STATIC_WEB_AT_ROOT=
